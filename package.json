{
  "name": "vite-project",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --env-file=.env node_modules/.bin/react-router build",
    "build:prod": "NODE_ENV=production node --env-file=.env node_modules/.bin/react-router build",
    "dev": "node --env-file=.env node_modules/.bin/react-router dev",
    "start": "node --env-file=.env node_modules/.bin/react-router build && npx serve build/client",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
    "copyright": "node scripts/copyright.mjs"
  },
  "dependencies": {
    "@react-router/node": "7.13.2",
    "@react-router/serve": "7.13.2",
    "framer-motion": "^12.38.0",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "7.13.2"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2"
  }
}
